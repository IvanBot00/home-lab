# ProtonVPN WireGuard credentials
# Generate a WireGuard config at: Account → Downloads → WireGuard configuration
# Copy the PrivateKey from the [Interface] block of the downloaded config file.
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here

# Optional: target a specific country (comma-separated list accepted)
VPN_SERVER_COUNTRIES=Netherlands

# Storage paths
GLUETUN_DATA_DIR=/appdata/gluetun
QBITTORRENT_CONFIG_DIR=/appdata/qbittorrent/config
DOWNLOADS_DIR=/mnt/downloads

# User/group for qBittorrent files
PUID=1000
PGID=1000
TZ=UTC
